   "source": [
    "import joblib\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "X = [[1,2],[2,3],[3,4],[4,5]]\n",
    "y = [0,0,1,1]\n",
    "\n",
    "model = RandomForestClassifier()\n",
    "model.fit(X, y)\n",
    "\n",
    "joblib.dump(model, \"model.pkl\")\n",
    "print(\"saved model.pkl\")\n"
   ]
  }
 ],
